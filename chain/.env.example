# ════════════════════════════════════════════════════════════════════
#  RareBlock chain module — environment variables
#  Copy to .env and fill with real values. NEVER commit .env to git.
# ════════════════════════════════════════════════════════════════════

# Hot wallet for deploys & server-side mint/transfer (initial MINTER)
PRIVATE_KEY=0x...

# RPC endpoints (Alchemy / public)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Block explorer verification (basescan.org → API key)
BASESCAN_API_KEY=

# ── Deployment params ──────────────────────────────────────────────
# DEFAULT_ADMIN_ROLE + PAUSER_ROLE holder. On mainnet → Gnosis Safe.
ADMIN_ADDRESS=0x...

# METADATA_ROLE holder (server signer that updates non-frozen URIs).
METADATA_MANAGER_ADDR=0x...

# ERC-2981 royalty receiver (RareBlock treasury).
ROYALTY_RECEIVER_ADDR=0x...
ROYALTY_BPS=250

# Collection metadata
COLLECTION_BASE_URI=ipfs://placeholder/{id}
COLLECTION_URI=ipfs://placeholder-collection.json
