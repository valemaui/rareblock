{
  "manifest_version": 3,
  "name": "RareBlock Hunter",
  "version": "2.2.1",
  "description": "Helper di scraping per RareBlock Collector — bypassa Cloudflare per Catawiki/eBay/Subito usando il tuo browser come proxy residenziale.",
  "author": "RareBlock",

  "permissions": [
    "scripting",
    "tabs",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://www.catawiki.com/*",
    "https://catawiki.com/*",
    "https://www.ebay.it/*",
    "https://www.ebay.com/*",
    "https://www.ebay.de/*",
    "https://www.ebay.co.uk/*",
    "https://www.ebay.fr/*",
    "https://www.ebay.es/*",
    "https://www.subito.it/*",
    "https://www.vinted.it/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.rareblock.eu/*",
        "https://rareblock.eu/*",
        "https://*.rareblock.eu/*",
        "https://claude.ai/*",
        "https://*.claude.ai/*",
        "http://localhost/*",
        "file:///*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "RareBlock Hunter"
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "minimum_chrome_version": "116"
}
